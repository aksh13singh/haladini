# ──────────────────────────────────────────────────────────────
# Haladini — environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` (it's gitignored).
# ──────────────────────────────────────────────────────────────

# ── Site ──────────────────────────────────────────────────────
# Public base URL of the site (used for SEO/OG absolute URLs).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ──────────────────────────────────────────────────
# Project URL & anon key — Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY. Used by admin + seed scripts.
# Never expose this to the browser. (Project Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Razorpay (primary payment gateway 🇮🇳) ─────────────────────
# Dashboard → Settings → API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# Webhook secret — Dashboard → Settings → Webhooks
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# ── Order notification emails (Resend) ───────────────────────
# API key from https://resend.com (free tier). When set, every new order
# emails the store owner.
RESEND_API_KEY=re_xxxxxxxxxxxxx
# Where alerts go (default: info@haladini.in). Until you verify the domain
# in Resend, set this to the email you signed up to Resend with.
ORDER_NOTIFY_TO=info@haladini.in
# Sender. Default is Resend's shared sender; after verifying haladini.in in
# Resend, use e.g. "Haladini Orders <orders@haladini.in>".
# ORDER_NOTIFY_FROM=Haladini Orders <orders@haladini.in>

# ── Stripe (optional — modular swap-in for later) ─────────────
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# Which payment provider is active: "razorpay" | "stripe"
NEXT_PUBLIC_PAYMENT_PROVIDER=razorpay
